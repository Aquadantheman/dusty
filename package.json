{
  "name": "dusty",
  "version": "0.1.0",
  "private": true,
  "description": "Discover vintage, antique, and thrift shops with sale tracking",
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=frontend",
    "build": "npm run build --workspace=frontend",
    "api": "cd api && uvicorn main:app --reload --port 8000",
    "etl:discover": "cd etl && python -m discovery.run",
    "etl:scrape-sales": "cd etl && python -m scrapers.run"
  }
}
