# Dusty Environment Configuration
# Copy this file to .env and fill in your values

# ===================
# Frontend (Next.js)
# ===================

# Mapbox public token (get from https://account.mapbox.com/access-tokens/)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_public_token_here

# API URL (local development)
NEXT_PUBLIC_API_URL=http://localhost:8000

# ===================
# Backend (FastAPI)
# ===================

# Debug mode (set to false in production)
DEBUG=true

# Database URL
# SQLite for local dev:
DATABASE_URL=sqlite+aiosqlite:///./dusty.db
# PostgreSQL for production:
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dusty

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ===================
# External APIs
# ===================

# Google Places API (for shop discovery)
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_PLACES_API_KEY=

# Yelp Fusion API (for shop discovery)
# Get from: https://www.yelp.com/developers/v3/manage_app
YELP_API_KEY=

# Mapbox secret token (for static map images)
MAPBOX_ACCESS_TOKEN=sk.your_mapbox_secret_token_here

# ===================
# Optional Services
# ===================

# Redis (for caching - optional)
REDIS_URL=

# Scraping settings
SCRAPE_INTERVAL_HOURS=6
MAX_CONCURRENT_SCRAPES=5
